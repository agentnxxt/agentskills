# ╔══════════════════════════════════════════════════════════════════╗
# ║  OpenAtonomyx — Environment Variables                          ║
# ║  Copy to .env and fill in all required values.                 ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── Global ────────────────────────────────────────────────────────
DOMAIN=agnxxt.com
PROTOCOL=https

# ── Logto (Identity Provider) ────────────────────────────────────
LOGTO_ENDPOINT=https://logto.${DOMAIN}
LOGTO_ADMIN_ENDPOINT=https://authadmin.openautonomyx.com
LOGTO_DB_HOST=logto-db
LOGTO_DB_NAME=logto
LOGTO_DB_USER=logto
LOGTO_DB_PASSWORD=              # REQUIRED — generate: openssl rand -hex 32
LOGTO_COOKIE_KEYS=              # REQUIRED — generate: openssl rand -base64 32
LOGTO_DB_URL=postgresql://${LOGTO_DB_USER}:${LOGTO_DB_PASSWORD}@${LOGTO_DB_HOST}:5432/${LOGTO_DB_NAME}

# ── Liferay (Portal / CMS) ──────────────────────────────────────
LIFERAY_HOST=https://liferay.${DOMAIN}
LIFERAY_DB_HOST=liferay-db
LIFERAY_DB_NAME=lportal
LIFERAY_DB_USER=liferay
LIFERAY_DB_PASSWORD=            # REQUIRED
LIFERAY_ADMIN_EMAIL=admin@${DOMAIN}
LIFERAY_ADMIN_PASSWORD=         # REQUIRED — local admin fallback
LIFERAY_SETUP_WIZARD=true       # Set to false after first boot
LIFERAY_OIDC_CLIENT_ID=        # REQUIRED — from Logto app
LIFERAY_OIDC_CLIENT_SECRET=    # REQUIRED — from Logto app

# ── Lago (Billing / Metering) ───────────────────────────────────
LAGO_HOST=https://lago.${DOMAIN}
LAGO_API_HOST=https://lago-api.${DOMAIN}
LAGO_DB_HOST=lago-db
LAGO_DB_NAME=lago
LAGO_DB_USER=lago
LAGO_DB_PASSWORD=               # REQUIRED
LAGO_REDIS_HOST=lago-redis
LAGO_SECRET_KEY_BASE=           # REQUIRED — generate: openssl rand -hex 64
LAGO_RSA_PRIVATE_KEY=           # REQUIRED — generate: openssl genrsa 2048
LAGO_ENCRYPTION_PRIMARY_KEY=    # REQUIRED — generate: openssl rand -hex 32
LAGO_ENCRYPTION_KEY_DERIVATION_SALT= # REQUIRED — generate: openssl rand -hex 32
LAGO_ENCRYPTION_DETERMINISTIC_KEY=   # REQUIRED — generate: openssl rand -hex 32
LAGO_OIDC_CLIENT_ID=            # REQUIRED — from Logto app
LAGO_OIDC_CLIENT_SECRET=        # REQUIRED — from Logto app

# ── ERPNext ──────────────────────────────────────────────────────
ERPNEXT_HOST=https://erp.${DOMAIN}
ERPNEXT_DB_HOST=erpnext-db
ERPNEXT_DB_NAME=erpnext
ERPNEXT_DB_ROOT_PASSWORD=       # REQUIRED
ERPNEXT_ADMIN_PASSWORD=         # REQUIRED
ERPNEXT_ENCRYPTION_KEY=         # REQUIRED — generate: openssl rand -hex 32
ERPNEXT_OIDC_CLIENT_ID=         # REQUIRED — from Logto app
ERPNEXT_OIDC_CLIENT_SECRET=     # REQUIRED — from Logto app

# ── Odoo ─────────────────────────────────────────────────────────
ODOO_HOST=https://odoo.${DOMAIN}
ODOO_DB_HOST=odoo-db
ODOO_DB_NAME=odoo
ODOO_DB_USER=odoo
ODOO_DB_PASSWORD=               # REQUIRED
ODOO_ADMIN_PASSWORD=            # REQUIRED
ODOO_OIDC_CLIENT_ID=            # REQUIRED — from Logto app
ODOO_OIDC_CLIENT_SECRET=        # REQUIRED — from Logto app

# ── n8n (Workflow Automation) ────────────────────────────────────
N8N_HOST=https://n8n.${DOMAIN}
N8N_DB_HOST=n8n-db
N8N_DB_NAME=n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=                # REQUIRED
N8N_ENCRYPTION_KEY=             # REQUIRED — generate: openssl rand -hex 32
N8N_ADMIN_EMAIL=admin@${DOMAIN} # Local owner account (fallback)
N8N_ADMIN_PASSWORD=             # REQUIRED — local admin fallback
N8N_OIDC_CLIENT_ID=             # REQUIRED — from Logto app
N8N_OIDC_CLIENT_SECRET=         # REQUIRED — from Logto app

# ── WuzAPI (WhatsApp API) ─────────────────────────────────────
WUZAPI_HOST=https://wuzapi.${DOMAIN}
WUZAPI_ADMIN_TOKEN=             # REQUIRED — generate: openssl rand -hex 32
WUZAPI_GLOBAL_ENCRYPTION_KEY=   # REQUIRED — generate: openssl rand -hex 16 (32 chars)
WUZAPI_GLOBAL_HMAC_KEY=         # OPTIONAL — generate: openssl rand -hex 32
WUZAPI_GLOBAL_WEBHOOK=          # OPTIONAL — global webhook URL
WUZAPI_DB_USER=wuzapi
WUZAPI_DB_PASSWORD=             # REQUIRED
WUZAPI_DB_NAME=wuzapi

# ── Conduit (Matrix Homeserver) ──────────────────────────────
CONDUIT_SERVER_NAME=matrix.${DOMAIN}
CONDUIT_ALLOW_REGISTRATION=true
CONDUIT_REGISTRATION_TOKEN=    # REQUIRED — generate: openssl rand -hex 32
CONDUIT_ALLOW_FEDERATION=true

# ── Sim Studio (AI Workflow Builder) ───────────────────────
SIMSTUDIO_HOST=https://sim.${DOMAIN}
SIMSTUDIO_SOCKET_URL=https://sim-ws.${DOMAIN}
SIMSTUDIO_AUTH_SECRET=          # REQUIRED — generate: openssl rand -hex 32
SIMSTUDIO_ENCRYPTION_KEY=       # REQUIRED — generate: openssl rand -hex 32
SIMSTUDIO_INTERNAL_API_SECRET=  # REQUIRED — generate: openssl rand -hex 32
SIMSTUDIO_API_ENCRYPTION_KEY=   # OPTIONAL — generate: openssl rand -hex 32
SIMSTUDIO_DB_USER=postgres
SIMSTUDIO_DB_PASSWORD=          # REQUIRED — generate: openssl rand -hex 32
SIMSTUDIO_DB_NAME=simstudio
SIMSTUDIO_OIDC_CLIENT_ID=       # REQUIRED — from Logto app
SIMSTUDIO_OIDC_CLIENT_SECRET=   # REQUIRED — from Logto app
SIMSTUDIO_COPILOT_API_KEY=      # OPTIONAL — from https://sim.ai
SIMSTUDIO_OLLAMA_URL=           # OPTIONAL — e.g. http://host.docker.internal:11434
SIMSTUDIO_REDIS_URL=            # OPTIONAL — e.g. redis://redis:6379
